<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a0a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Status -->
        <TextView
            android:id="@+id/status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textColor="#00d4aa"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#111"
            android:layout_marginBottom="8dp" />

        <!-- Device list -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DEVICES"
            android:textColor="#666"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:id="@+id/device_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/scan_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/connect_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connect"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/disconnect_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disconnect"
                android:enabled="false" />
        </LinearLayout>

        <!-- Test -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TEST"
            android:textColor="#666"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/ping_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ping" />

        <!-- WiFi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WIFI PROVISIONING"
            android:textColor="#666"
            android:textSize="12sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/ssid_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WiFi SSID"
            android:textColor="#ddd"
            android:textColorHint="#444"
            android:background="#111"
            android:padding="10dp"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/pass_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="WiFi Password"
            android:inputType="textPassword"
            android:textColor="#ddd"
            android:textColorHint="#444"
            android:background="#111"
            android:padding="10dp"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/scan_wifi_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan WiFi"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/wifi_connect_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Connect WiFi" />
        </LinearLayout>

        <!-- Command -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SYSTEM COMMAND"
            android:textColor="#666"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/cmd_input"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="uptime"
                android:textColor="#ddd"
                android:textColorHint="#444"
                android:background="#111"
                android:padding="10dp"
                android:layout_marginEnd="4dp" />

            <Button
                android:id="@+id/cmd_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Run" />
        </LinearLayout>

        <!-- Output -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OUTPUT"
            android:textColor="#666"
            android:textSize="12sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/output_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#111"
            android:padding="10dp"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textColor="#999"
            android:minHeight="100dp"
            android:text="--" />

    </LinearLayout>
</ScrollView>
